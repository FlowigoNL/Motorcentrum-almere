  <script type='text/javascript'>/**
 * WPCodeBox (JS – Frontend)
 * Form A: eerst model kiezen, daarna beschikbare tijdsloten tonen
 * Extra UX: bij keuze van een tijdslot wordt beschikbaarheid opnieuw ververst
 */
(function () {
  const FORM_A_ID = 15;
  const FIELD_DEMO_DAG_ID = 1;
  const FIELD_MODEL = 3;
  const FIELD_TIJD_SLOT = 4;

  function qs(sel, root) { return (root || document).querySelector(sel); }
  function qsa(sel, root) { return Array.from((root || document).querySelectorAll(sel)); }

  function getForm() {
    return document.getElementById('gform_' + FORM_A_ID);
  }

  function getDemoDagId(form) {
    const el = qs('input[name="input_' + FIELD_DEMO_DAG_ID + '"]', form);
    return el ? parseInt(el.value || '0', 10) : 0;
  }

  function getSelectedModel(form) {
    const checked = qs('input[name="input_' + FIELD_MODEL + '"]:checked', form);
    return checked ? checked.value : '';
  }

  function getSelectedSlot(form) {
    const checked = qs('input[name="input_' + FIELD_TIJD_SLOT + '"]:checked', form);
    return checked ? checked.value : '';
  }

  function getTimeSlotFieldWrapper(form) {
    return qs('#field_' + FORM_A_ID + '_' + FIELD_TIJD_SLOT, form) || qs('#field_' + FIELD_TIJD_SLOT, form);
  }

  function resetTimeSlots(form) {
    const radios = qsa('input[name="input_' + FIELD_TIJD_SLOT + '"]', form);
    radios.forEach(function (radio) {
      radio.disabled = true;
      radio.checked = false;
      const li = radio.closest('li');
      if (li) li.style.display = 'none';
      const label = li ? li.querySelector('label') : null;
      if (label) label.textContent = label.textContent.replace(' (vol)', '');
    });
  }

  function applySlots(form, slots, keepSelectedValue) {
    const radios = qsa('input[name="input_' + FIELD_TIJD_SLOT + '"]', form);
    const map = {};
    slots.forEach(function (slot) {
      map[slot.value] = slot;
    });

    radios.forEach(function (radio) {
      const li = radio.closest('li');
      const label = li ? li.querySelector('label') : null;
      const slot = map[radio.value];

      if (!slot || parseInt(slot.remaining, 10) <= 0) {
        radio.disabled = true;
        radio.checked = false;
        if (li) li.style.display = 'none';
        if (label && slot && !label.textContent.includes(' (vol)')) {
          label.textContent = slot.label + ' (vol)';
        }
        return;
      }

      radio.disabled = false;
      radio.checked = keepSelectedValue && radio.value === keepSelectedValue;
      if (li) li.style.display = '';
      if (label) label.textContent = slot.label;
    });
  }

  async function fetchSlots(form) {
    const demoDagId = getDemoDagId(form);
    const model = getSelectedModel(form);

    if (!demoDagId || !model) return [];

    const url = '/wp-json/cfmoto/v1/availability?demo_dag_id=' + encodeURIComponent(demoDagId) + '&model=' + encodeURIComponent(model);
    const res = await fetch(url, { credentials: 'same-origin' });
    if (!res.ok) return [];

    const json = await res.json();
    return json.slots || [];
  }

  async function refreshSlots(form, keepSelected) {
    const model = getSelectedModel(form);
    const wrapper = getTimeSlotFieldWrapper(form);
    const selectedSlot = keepSelected ? getSelectedSlot(form) : '';

    resetTimeSlots(form);

    if (wrapper) {
      wrapper.style.display = model ? '' : 'none';
    }

    if (!model) return;

    const slots = await fetchSlots(form);
    applySlots(form, slots, selectedSlot);
  }

  document.addEventListener('DOMContentLoaded', function () {
    const form = getForm();
    if (!form) return;

    const wrapper = getTimeSlotFieldWrapper(form);
    if (wrapper) wrapper.style.display = 'none';

    form.addEventListener('change', function (e) {
      if (!e.target) return;

      if (e.target.name === 'input_' + FIELD_MODEL) {
        refreshSlots(form, false);
      }

      if (e.target.name === 'input_' + FIELD_TIJD_SLOT) {
        refreshSlots(form, true);
      }
    });
  });
})();
</script><style type='text/css'  class='wpcb2-inline-style'>
/*
 * LANDSPECIFIEKE VISIBILITY (client-side, caching-proof)
 * -------------------------------------------------------
 * De HTML bevat ALLE landvarianten, maar wordt client-side gefilterd.
 * Dit voorkomt problemen met caching of server-side conditions.
 *
 * .content-belgie / .content-luxemburg / .content-nederland
 * → worden standaard verborgen
 * → JS toont exact de variant die overeenkomt met cookie "land"
 */

body.is-frontend .content-belgie,
body.is-frontend .content-luxemburg,
body.is-frontend .content-nederland {
    display:none !important;
}

body.is-frontend .land-visible {
    display:flex !important;
}

/*
 * LANDSELECTOR (choose region popup/section)
 * ------------------------------------------
 * Deze wordt enkel getoond:
 * - wanneer cookie 'land' niet bestaat
 * - of wanneer gebruiker expliciet zijn land wil wijzigen
 * (dan voegt JS de class .force-show-selector toe aan <body>)
 */

.landselector {
    display: none;
}

/*
 * .land-visible wordt door JS toegevoegd aan ELKE sectie die zichtbaar moet zijn
 * Zowel de content-blokken als de landselector gebruiken dit principe.
 *
 * display: unset → behoudt originele layout (flex, grid, etc.)
 */

.land-visible {
    display: unset !important;
}

/*
 * LANDSELECTOR FORCEREN
 * ----------------------
 * Deze CSS toont de landselector wanneer <body> de class
 * .force-show-selector bevat.
 * Wordt gebruikt door de 'wijzig land' knoppen.
 */

.force-show-selector .landselector {
    display: unset !important;
}

/*
 * FRONTEND-ONLY VISIBILITY VOOR LANDKNOPPEN
 * -----------------------------------------
 * In de frontend moet altijd maar één regio-knop zichtbaar zijn.
 * JS bepaalt via de class .show-btn welke knop zichtbaar wordt.
 *
 * We gebruiken body.is-frontend omdat Oxygen Builder de frontend-HTML
 * in een iframe laadt en we zo 100% zeker zijn dat deze CSS
 * NIET geldt binnen de builder.
 */

body.is-frontend .region-btn {
    display: none !important;
}

/*
 * De door JS geactiveerde knop (met class .show-btn)
 * moet zichtbaar worden in de frontend.
 */

body.is-frontend .show-btn {
    display: flex !important;
}

/*nav prijzen*/
.land-flex.land-visible {
    display: flex !important;
    flex-direction: row;
    align-items: center;
    gap: 14px;
    color: #009aaa;
    font-weight: 500;
}


