<script type='text/javascript'>// Add your JS Code here, don't include the <script> tags
/*
 * LANDLOGICA: tonen van landselector + land-content
 * -------------------------------------------------
 * - Geen cookie? → landselector tonen
 * - Cookie wel? → selector verbergen, juiste content tonen
 */

function getCookie(name) {
    const value = `; ${document.cookie}`;
    const parts = value.split(`; ${name}=`);
    if (parts.length === 2) return parts.pop().split(';').shift();
}

document.addEventListener("DOMContentLoaded", function () {

    const land = getCookie('land');

    // 1. Landselector tonen/verbergen
    const selector = document.querySelector('.landselector');
    if (selector) {
        if (!land) {
            selector.classList.add('land-visible');
        }
    }

    // 2. Alle landcontent blokkeren
    const all = document.querySelectorAll('.content-belgie, .content-luxemburg, .content-nederland');
    all.forEach(el => el.classList.remove('land-visible'));

    // 3. Als landcookie bestaat → juiste content tonen
    if (land) {
        document.querySelectorAll('.content-' + land).forEach(el => {
            el.classList.add('land-visible');
        });
    }
});


/*landselector tonen*/
function showLandSelector() {
    document.body.classList.add('force-show-selector');
}

document.querySelectorAll('.change-land').forEach(function(btn) {
    btn.addEventListener('click', function() {
        // Cookie verwijderen
        document.cookie = "land=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";

        // Landselector terug tonen
        document.body.classList.add('force-show-selector');
    });
});


/*
 * REGION BUTTON LOGICA
 * --------------------
 * Toont precies één knop op basis van land-cookie:
 * - geen cookie -> .region-none
 * - belgie -> .region-belgie
 * - nederland -> .region-nederland
 * - luxemburg -> .region-luxemburg
 */

function getCookie(name) {
    const value = `; ${document.cookie}`;
    const parts = value.split(`; ${name}=`);
    if (parts.length === 2) return parts.pop().split(';').shift();
}

document.addEventListener("DOMContentLoaded", function () {

    const land = getCookie('land');

    // 1. Verberg alle knoppen
    document.querySelectorAll('.region-btn').forEach(function(btn){
        btn.classList.remove('show-btn');
    });

    // 2. Toon juiste knop
    if (!land) {
        document.querySelector('.region-none').classList.add('show-btn');
    } else {
        const targetBtn = document.querySelector('.region-' + land);
        if (targetBtn) {
            targetBtn.classList.add('show-btn');
        }
    }

    // 3. Alle knoppen laten de landselector opnieuw verschijnen
    document.querySelectorAll('.region-btn').forEach(function(btn){
        btn.addEventListener('click', function() {
            // Cookie verwijderen
            document.cookie = "land=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
            // Landselector tonen
            document.body.classList.add('force-show-selector');
        });
    });
});

/*fix landen in nav*/
// Markeer frontend (niet-builder)
document.addEventListener("DOMContentLoaded", function () {
    if (!document.body.classList.contains('oxygen-builder-body')) {
        document.body.classList.add('is-frontend');
    }
});

</script><script>jQuery(document).on('click','a[href*="#"]',function(t){if(jQuery(t.target).closest('.wc-tabs').length>0){return}if(jQuery(this).is('[href="#"]')||jQuery(this).is('[href="#0"]')||jQuery(this).is('[href*="replytocom"]')){return};if(location.pathname.replace(/^\//,"")==this.pathname.replace(/^\//,"")&&location.hostname==this.hostname){var e=jQuery(this.hash);(e=e.length?e:jQuery("[name="+this.hash.slice(1)+"]")).length&&(t.preventDefault(),jQuery("html, body").animate({scrollTop:e.offset().top-280},800))}});</script><style>.ct-FontAwesomeicon-map-marker{width:0.57142857142857em}</style>
